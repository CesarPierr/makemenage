generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HouseholdRole {
  owner
  admin
  member
}

enum AvailabilityType {
  weekly_rule
  date_range_absence
}

enum RecurrenceType {
  daily
  every_x_days
  weekly
  every_x_weeks
  monthly_simple
}

enum RecurrenceMode {
  FIXED
  SLIDING
}

enum AssignmentMode {
  fixed
  manual
  strict_alternation
  round_robin
  least_assigned_count
  least_assigned_minutes
}

enum OccurrenceStatus {
  planned
  due
  overdue
  completed
  skipped
  rescheduled
  cancelled
}

enum OccurrenceActionType {
  created
  assigned
  completed
  skipped
  rescheduled
  reassigned
  edited
  cancelled
}

enum IntegrationProvider {
  mcp_openclaw
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  displayName        String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  lastLoginAt        DateTime?
  sessions           Session[]
  passwordResetTokens PasswordResetToken[]
  memberships        HouseholdMember[]
  households         Household[]        @relation("HouseholdOwner")
  acceptedInvitations HouseholdInvite[] @relation("AcceptedHouseholdInvites")
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Household {
  id              String            @id @default(cuid())
  name            String
  timezone        String
  createdByUserId String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdBy       User              @relation("HouseholdOwner", fields: [createdByUserId], references: [id])
  members         HouseholdMember[]
  invites         HouseholdInvite[]
  integrations    HouseholdIntegration[]
  tasks           TaskTemplate[]
  occurrences     TaskOccurrence[]
  holidays        HouseholdHoliday[]
  savingsBoxes    SavingsBox[]
  savingsCalculators SavingsCalculator[]

  @@index([createdByUserId])
}

model HouseholdMember {
  id                    String             @id @default(cuid())
  householdId           String
  userId                String?
  displayName           String
  color                 String
  role                  HouseholdRole
  isActive              Boolean            @default(true)
  weightingFactor       Float              @default(1)
  weeklyCapacityMinutes Int?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  household             Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user                  User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  availabilities        MemberAvailability[]
  createdTasks          TaskTemplate[]     @relation("TaskTemplateCreator")
  createdInvitations    HouseholdInvite[]  @relation("CreatedHouseholdInvites")
  assignedOccurrences   TaskOccurrence[]   @relation("OccurrenceAssignee")
  completedOccurrences  TaskOccurrence[]   @relation("OccurrenceCompleter")
  actionLogs            OccurrenceActionLog[]
  occurrenceComments    OccurrenceComment[]
  pushSubscriptions     PushSubscription[]

  @@index([householdId])
  @@index([userId])
  @@unique([householdId, userId])
}

model HouseholdInvite {
  id                String           @id @default(cuid())
  householdId       String
  createdByMemberId String?
  acceptedByUserId  String?
  token             String           @unique
  code              String           @unique
  role              HouseholdRole    @default(member)
  expiresAt         DateTime
  acceptedAt        DateTime?
  revokedAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  household         Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdByMember   HouseholdMember? @relation("CreatedHouseholdInvites", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  acceptedByUser    User?            @relation("AcceptedHouseholdInvites", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([householdId, createdAt])
  @@index([expiresAt])
}

model HouseholdIntegration {
  id            String              @id @default(cuid())
  householdId   String
  provider      IntegrationProvider
  isEnabled     Boolean             @default(false)
  serverUrl     String?
  clientLabel   String?
  apiKeyHash    String?
  apiKeyPreview String?
  config        Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  household     Household           @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, provider])
  @@index([provider, isEnabled])
}

model MemberAvailability {
  id        String           @id @default(cuid())
  memberId  String
  type      AvailabilityType
  weekdays  Json?
  startDate DateTime
  endDate   DateTime
  notes     String?
  createdAt DateTime         @default(now())
  member    HouseholdMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, startDate, endDate])
}

model RecurrenceRule {
  id                 String         @id @default(cuid())
  type               RecurrenceType
  mode               RecurrenceMode @default(SLIDING)
  interval           Int            @default(1)
  weekdays           Json?
  dayOfMonth         Int?
  anchorDate         DateTime
  generateTimeOfDay  String?
  dueOffsetDays      Int            @default(0)
  config             Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  task               TaskTemplate?
}

model AssignmentRule {
  id                           String          @id @default(cuid())
  mode                         AssignmentMode
  eligibleMemberIds            Json
  fixedMemberId                String?
  rotationOrder                Json?
  fairnessWindowDays           Int?
  preserveRotationOnSkip       Boolean         @default(true)
  preserveRotationOnReschedule Boolean         @default(true)
  rebalanceOnMemberAbsence     Boolean         @default(true)
  lockAssigneeAfterGeneration  Boolean         @default(true)
  config                       Json?
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt
  task                         TaskTemplate?
}

model TaskTemplate {
  id               String          @id @default(cuid())
  householdId      String
  title            String
  description      String?
  category         String?
  room             String?
  icon             String?
  color            String          @default("#D8643D")
  tags             Json?
  estimatedMinutes Int             @default(30)
  difficulty       Int?
  priority         Int             @default(2)
  isActive         Boolean         @default(true)
  isCollective     Boolean         @default(false)
  startsOn         DateTime
  endsOn           DateTime?
  lastCompletedAt  DateTime?
  recurrenceRuleId String          @unique
  assignmentRuleId String          @unique
  createdByMemberId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  household        Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recurrenceRule   RecurrenceRule  @relation(fields: [recurrenceRuleId], references: [id], onDelete: Cascade)
  assignmentRule   AssignmentRule  @relation(fields: [assignmentRuleId], references: [id], onDelete: Cascade)
  createdByMember  HouseholdMember? @relation("TaskTemplateCreator", fields: [createdByMemberId], references: [id], onDelete: SetNull)
  occurrences      TaskOccurrence[]

  @@index([householdId])
}

model TaskOccurrence {
  id                  String               @id @default(cuid())
  householdId         String
  taskTemplateId      String
  scheduledDate       DateTime
  dueDate             DateTime
  assignedMemberId    String?
  status              OccurrenceStatus     @default(planned)
  sourceGenerationKey String               @unique
  generationVersion   Int                  @default(1)
  originalScheduledDate DateTime
  completedAt         DateTime?
  completedByMemberId String?
  actualMinutes       Int?
  notes               String?
  wasCompletedAlone   Boolean?
  isManuallyModified  Boolean              @default(false)
  rescheduleCount     Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  household           Household            @relation(fields: [householdId], references: [id], onDelete: Cascade)
  taskTemplate        TaskTemplate         @relation(fields: [taskTemplateId], references: [id], onDelete: Cascade)
  assignedMember      HouseholdMember?     @relation("OccurrenceAssignee", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  completedByMember   HouseholdMember?     @relation("OccurrenceCompleter", fields: [completedByMemberId], references: [id], onDelete: SetNull)
  logs                OccurrenceActionLog[]
  comments            OccurrenceComment[]

  @@index([householdId, scheduledDate])
  @@index([householdId, status, scheduledDate])
  @@index([householdId, assignedMemberId, scheduledDate])
  @@index([assignedMemberId, scheduledDate])
  @@index([taskTemplateId])
}

model HouseholdHoliday {
  id          String    @id @default(cuid())
  householdId String
  startDate   DateTime
  endDate     DateTime
  label       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, startDate])
}

model OccurrenceActionLog {
  id             String               @id @default(cuid())
  occurrenceId   String
  actionType     OccurrenceActionType
  actorMemberId  String?
  previousValues Json?
  newValues      Json?
  createdAt      DateTime             @default(now())
  occurrence     TaskOccurrence       @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  actorMember    HouseholdMember?     @relation(fields: [actorMemberId], references: [id], onDelete: SetNull)

  @@index([occurrenceId])
}

model OccurrenceComment {
  id           String           @id @default(cuid())
  occurrenceId String
  authorId     String?
  body         String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  occurrence   TaskOccurrence   @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  author       HouseholdMember? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([occurrenceId, createdAt])
}

model PushSubscription {
  id         String   @id @default(cuid())
  memberId   String
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  member     HouseholdMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

enum SavingsBoxKind {
  savings
  project
  debt
  provision
}

enum SavingsEntryType {
  deposit
  withdrawal
  transfer_in
  transfer_out
  auto_fill
  adjustment
}

enum SavingsCalculatorFieldType {
  number
  amount
  percent
}

enum SavingsCalculatorResultMode {
  deposit
  withdrawal
}

enum SavingsCalculatorNegativeMode {
  clamp_to_zero
  convert_to_opposite
}

enum SavingsCalculatorRoundingMode {
  cents
  euro_floor
  euro_ceil
  euro_nearest
}

model SavingsBox {
  id                String         @id @default(cuid())
  householdId       String
  name              String
  kind              SavingsBoxKind @default(savings)
  icon              String?
  color             String     @default("#D8643D")
  targetAmount      Decimal?   @db.Decimal(12, 2)
  targetDate        DateTime?
  allowNegative     Boolean    @default(false)
  isArchived        Boolean    @default(false)
  sortOrder         Int        @default(0)
  notes             String?
  createdByMemberId String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  household       Household              @relation(fields: [householdId], references: [id], onDelete: Cascade)
  autoFillRule    SavingsAutoFillRule?
  entries         SavingsEntry[]
  outTransfers    SavingsTransfer[]      @relation("TransferFrom")
  inTransfers     SavingsTransfer[]      @relation("TransferTo")
  calculators     SavingsCalculator[]
  calculatorRuns  SavingsCalculatorRun[]

  @@index([householdId, isArchived, sortOrder])
}

model SavingsAutoFillRule {
  id              String         @id @default(cuid())
  boxId           String         @unique
  amount          Decimal        @db.Decimal(12, 2)
  type            RecurrenceType
  interval        Int            @default(1)
  weekdays        Json?
  dayOfMonth      Int?
  anchorDate      DateTime
  startsOn        DateTime
  endsOn          DateTime?
  isPaused        Boolean        @default(false)
  lastAppliedOn   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  box SavingsBox @relation(fields: [boxId], references: [id], onDelete: Cascade)
}

model SavingsEntry {
  id              String           @id @default(cuid())
  boxId           String
  householdId     String
  type            SavingsEntryType
  amount          Decimal          @db.Decimal(12, 2)
  occurredOn      DateTime
  reason          String?
  authorMemberId  String?
  transferId      String?
  autoFillRuleId  String?
  autoFillKey     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  box      SavingsBox       @relation(fields: [boxId], references: [id], onDelete: Cascade)
  transfer SavingsTransfer? @relation(fields: [transferId], references: [id], onDelete: SetNull)
  calculatorRun SavingsCalculatorRun?

  @@unique([autoFillRuleId, autoFillKey])
  @@index([boxId, occurredOn])
  @@index([householdId, occurredOn])
  @@index([transferId])
}

model SavingsTransfer {
  id             String   @id @default(cuid())
  householdId    String
  fromBoxId      String
  toBoxId        String
  amount         Decimal  @db.Decimal(12, 2)
  occurredOn     DateTime
  reason         String?
  authorMemberId String?
  createdAt      DateTime @default(now())

  fromBox SavingsBox      @relation("TransferFrom", fields: [fromBoxId], references: [id], onDelete: Cascade)
  toBox   SavingsBox      @relation("TransferTo", fields: [toBoxId], references: [id], onDelete: Cascade)
  entries SavingsEntry[]

  @@index([householdId, occurredOn])
  @@index([fromBoxId])
  @@index([toBoxId])
}

model SavingsCalculator {
  id             String                         @id @default(cuid())
  householdId    String
  boxId          String
  name           String
  description    String?
  formula        String
  reasonTemplate String?
  resultMode     SavingsCalculatorResultMode    @default(deposit)
  negativeMode   SavingsCalculatorNegativeMode  @default(clamp_to_zero)
  roundingMode   SavingsCalculatorRoundingMode  @default(cents)
  isArchived     Boolean                        @default(false)
  sortOrder      Int                            @default(0)
  createdByMemberId String?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt

  household      Household                      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  box            SavingsBox                     @relation(fields: [boxId], references: [id], onDelete: Cascade)
  fields         SavingsCalculatorField[]
  runs           SavingsCalculatorRun[]

  @@index([householdId, isArchived, sortOrder])
  @@index([boxId, isArchived, sortOrder])
}

model SavingsCalculatorField {
  id             String                     @id @default(cuid())
  calculatorId   String
  key            String
  label          String
  type           SavingsCalculatorFieldType @default(number)
  defaultValue   Decimal?                   @db.Decimal(12, 4)
  helperText     String?
  isRequired     Boolean                    @default(true)
  sortOrder      Int                        @default(0)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  calculator     SavingsCalculator          @relation(fields: [calculatorId], references: [id], onDelete: Cascade)

  @@unique([calculatorId, key])
  @@index([calculatorId, sortOrder])
}

model SavingsCalculatorRun {
  id             String            @id @default(cuid())
  calculatorId   String
  householdId    String
  boxId          String
  inputValues    Json
  rawResult      Decimal           @db.Decimal(12, 4)
  resultAmount   Decimal           @db.Decimal(12, 2)
  entryType      SavingsEntryType
  entryId        String?           @unique
  authorMemberId String?
  createdAt      DateTime          @default(now())

  calculator     SavingsCalculator @relation(fields: [calculatorId], references: [id], onDelete: Cascade)
  box            SavingsBox        @relation(fields: [boxId], references: [id], onDelete: Cascade)
  entry          SavingsEntry?     @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([calculatorId, createdAt])
  @@index([householdId, createdAt])
  @@index([boxId, createdAt])
}
